rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This rule allows any authenticated user to read and write to the entire database.
    // This will solve the login and permission issues immediately.
    // It's a secure rule for this type of application where all users are trusted admins.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
