rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que cualquier usuario autenticado pueda leer y escribir en toda la base de datos.
    // Esto resuelve el problema de "permisos insuficientes" al iniciar sesión.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
