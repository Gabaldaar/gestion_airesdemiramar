rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // A user is signed in if their auth object is not null.
    function isSignedIn() {
      return request.auth != null;
    }

    // A server process (like a Next.js server action) runs with admin privileges
    // and has a null auth object. We trust our own server code.
    function isServerProcess() {
      return request.auth == null;
    }

    // By default, allow authenticated users OR our trusted server processes to read/write.
    // This provides a good baseline for development. Specific collections can have stricter rules.
    match /{document=**} {
      allow read, write: if isSignedIn() || isServerProcess();
    }
  }
}
