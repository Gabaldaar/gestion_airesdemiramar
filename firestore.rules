rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isMember(workspaceId) {
      // Check if the user is a document in the members subcollection.
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)) != null;
    }
    
    // The workspace document itself can be read or created by any authenticated user.
    match /workspaces/{workspaceId} {
      allow read, write: if request.auth != null;
    }

    // Specific rules for the members collection to break the circular dependency
    match /workspaces/{workspaceId}/members/{userId} {
      // A user can ALWAYS create, read, or update their own member document.
      allow read, write: if request.auth.uid == userId;
    }
    
    // Allow authenticated users to LIST members, which is needed by the auth provider to check for new users.
    match /workspaces/{workspaceId}/members {
        allow list: if request.auth != null;
    }

    // For ALL OTHER collections inside a workspace, the user must be a member.
    match /workspaces/{workspaceId}/{collection}/{docId=**} {
      allow read, write: if collection != 'members' && isMember(workspaceId);
    }
    
    // Rules for push subscriptions are separate
    match /pushSubscriptions/{subscriptionId} {
      allow create, write: if request.auth != null;
      allow read, delete: if request.auth != null && resource.data.keys.p256dh == request.resource.data.keys.p256dh;
    }
  }
}
