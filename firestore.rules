
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verifica si el usuario está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Verifica si es el Administrador Maestro por UID (Solo para telemetría y perfiles)
    function isMasterAdmin() {
      return isSignedIn() && request.auth.uid == "ymBtFDZUWKR7VCxWNTHWflXc5mx1";
    }

    // Helper: Obtiene el documento del perfil de usuario (provider)
    function getUserData() {
      return get(/databases/$(database)/documents/providers/$(request.auth.uid)).data;
    }
    
    // Regla de Aislamiento Estricto:
    // El documento debe pertenecer a la organización del usuario.
    function canAccess(docData) {
      let docOrgId = 'orgId' in docData ? docData.orgId : 'global';
      let userOrgId = 'orgId' in getUserData() ? getUserData().orgId : 'global';
      return isSignedIn() && (docOrgId == userOrgId);
    }

    // Reglas para la colección de proveedores (donde están los roles)
    match /providers/{document} {
      // El Administrador Maestro puede leer perfiles para soporte, pero no editarlos si no son suyos
      allow read: if isMasterAdmin() || (isSignedIn() && document == request.auth.uid);
      allow write: if isSignedIn() && (document == request.auth.uid || isMasterAdmin());
    }

    // Reglas generales: ELIMINADO EL BYPASS DE MASTER ADMIN para evitar mezcla de datos
    match /{collection}/{document} {
      allow read, write: if isSignedIn() && (
        canAccess(resource.data) ||
        canAccess(request.resource.data)
      );
    }
    
    // Reglas específicas para configuraciones globales por organización
    match /settings/{settingId} {
       allow read, write: if isSignedIn();
    }

    // Reglas para telemetría del sistema (Solo Master Admin)
    match /system_stats/{orgId} {
      allow read: if isMasterAdmin();
      allow write: if isSignedIn();
    }
  }
}
