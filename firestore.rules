rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: This rule is insecure and allows anyone to read/write to your database.
    // It is a temporary measure to make the application functional.
    // We need to implement a more secure solution.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
