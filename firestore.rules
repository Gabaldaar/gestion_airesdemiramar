rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Un usuario siempre puede leer o escribir su propio documento de miembro.
    match /workspaces/{workspaceId}/members/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Para cualquier otro documento dentro de un workspace, el usuario debe ser un miembro verificado.
    match /workspaces/{workspaceId}/{document=**} {
      allow read, write: if get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)) != null;
    }

    // Las suscripciones a notificaciones son por usuario, no por workspace.
    match /pushSubscriptions/{subscriptionId} {
        allow read, delete: if request.auth != null && resource.data.keys.p256dh == request.resource.data.keys.p256dh;
        allow create, write: if request.auth != null;
    }
  }
}
