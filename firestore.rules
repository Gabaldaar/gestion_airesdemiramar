rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- REGLAS SIMPLIFICADAS PARA APP PERSONAL ---
    // Permite que cualquier usuario autenticado pueda leer y escribir
    // en cualquier documento dentro del workspace personal.
    // Esto soluciona el bloqueo de "permisos insuficientes" al iniciar sesión por primera vez.
    match /workspaces/miramar-personal-workspace/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas para suscripciones push.
    match /pushSubscriptions/{subscriptionId} {
      allow create, write: if request.auth != null;
      allow read, delete: if request.auth != null && resource.data.keys.p256dh == request.resource.data.keys.p256dh;
    }
  }
}
