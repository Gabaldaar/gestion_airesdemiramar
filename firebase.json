
{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "codebase": "default",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-had-error.log"
    ],
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" install --legacy-peer-deps",
      "npm --prefix \"$RESOURCE_DIR\" run build",
      "rm -f \"$RESOURCE_DIR/package-lock.json\""
    ]
  }
}
