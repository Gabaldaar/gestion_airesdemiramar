{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "target": "regentum",
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "us-central1"
    }
  },
  "functions": {
    "source": "functions",
    "codebase": "default",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-had-error.log"
    ],
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" install --legacy-peer-deps",
      "npm --prefix \"$RESOURCE_DIR\" run build",
      "rm -f \"$RESOURCE_DIR/package-lock.json\""
    ]
  }
}
