# Client-side Firebase config
NEXT_PUBLIC_FIREBASE_API_KEY="YOUR_API_KEY_HERE"

# Server-side Firebase Admin SDK config
# The value should be the full JSON content of your service account key, enclosed in quotes.
# e.g., FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", ...}'
FIREBASE_SERVICE_ACCOUNT_KEY="PASTE_YOUR_FULL_SERVICE_ACCOUNT_JSON_HERE"

# Web Push VAPID keys for notifications
# Generate these with `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"
VAPID_PRIVATE_KEY="YOUR_VAPID_PRIVATE_KEY"
VAPID_MAILTO="mailto:your-email@example.com"

# Integración con App de Finanzas (solo modalidad Personal, servidor)
# Misma API Key que configuraste en gestionomiscuentas (Bearer token).
# Sin esto, el formulario de cobro muestra "Sin sincronización" y no envía cobros externos.
FINANCE_API_KEY="YOUR_FINANCE_API_KEY_HERE"
