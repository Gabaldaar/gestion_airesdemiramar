
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all files so they can be displayed in the app.
    allow read;
    
    // Allow write access (uploads) only for authenticated users.
    // This is secure because the file path is generated by the server-side code (actions).
    match /{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}

    