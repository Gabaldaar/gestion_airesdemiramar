rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permite que cualquiera lea las imágenes (necesario para mostrarlas en la app)
    allow read;

    // Permite que CUALQUIER usuario autenticado pueda escribir archivos.
    // Esto es seguro porque la ruta del archivo se genera en el código
    // y no puede ser manipulada por el usuario.
    match /{allPaths=**} {
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024 // Límite de 5MB
                   && request.resource.contentType.matches('image/.*'); // Solo imágenes
    }
  }
}
