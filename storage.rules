rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read images (necessary for displaying them in the app)
    allow read;

    // Allow any authenticated user to write files, with size and type restrictions.
    // This is secure because the file path is generated by the code and includes the user's workspace/property.
    match /{allPaths=**} {
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                   && request.resource.contentType.matches('image/.*'); // Only images
    }
  }
}
