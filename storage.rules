
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow unauthenticated users to upload their signatures to this specific path.
    match /tenant_signatures/{allPaths=**} {
      allow read, write;
    }

    // For all other paths, require authentication to write.
    // Public reads are allowed for all files.
    match /{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }
  }
}
