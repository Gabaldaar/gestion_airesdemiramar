rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read files. This is necessary for displaying images.
    allow read;

    // Allow any authenticated user to write files.
    // This is secure because the file path is generated by server-side code.
    match /{allPaths=**} {
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                   && request.resource.contentType.matches('image/.*'); // Only images
    }
  }
}
