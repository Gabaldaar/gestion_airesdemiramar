rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // ADVERTENCIA: Regla temporalmente permisiva para depuración.
      // Permite a cualquier usuario leer y escribir.
      // Se debe asegurar antes de pasar a producción.
      allow read, write;
    }
  }
}
