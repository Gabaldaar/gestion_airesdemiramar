rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Un usuario solo puede escribir en las propiedades de su workspace.
    // La regla `get` es más robusta que `exists` en este contexto.
    match /workspaces/{workspaceId}/properties/{propertyId}/{fileName} {
      // Permite a cualquiera leer las imágenes, ya que se mostrarán en la app.
      allow read;
      // Solo permite escribir a usuarios autenticados que son miembros del workspace.
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)) != null
                   && request.resource.size < 5 * 1024 * 1024 // Límite de 5MB
                   && request.resource.contentType.matches('image/.*'); // Solo imágenes
    }
  }
}
